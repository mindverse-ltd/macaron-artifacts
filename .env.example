# Copy to .env (or export in your shell) before starting the server.
# .env is git-ignored — never commit real values.

# Macaron OpenAI-compatible endpoint (used by GenUI Builder and by the
# "Macaron 0.6" model option in the chat model picker).
MACARON_API_BASE=https://<macaron-host>/v1
MACARON_API_KEY=<your-macaron-api-key>

# Optional — override the model id sent to Macaron.
# MACARON_MODEL=macaron-0.6

# Optional — server bind port/host.
# MACARON_PORT=7878
# MACARON_HOST=127.0.0.1

# Optional — server log level (default: info).
# MACARON_LOG_LEVEL=debug
